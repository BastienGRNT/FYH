{% extends "layout.html.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
    {# Import des scripts délocalisés #}
    <script src="/scripts/escapeHTML.js"></script>
    <script src="/scripts/userSearch.js"></script>
    <script src="/scripts/dragAndDrop.js"></script>

    <div class="col-12 text-center mb-5">
        <h1>Prochains Hackathons</h1>
        <p class="lead">Trouvez l'événement qui va changer votre carrière.</p>

        <label for="search" class="visually-hidden">Rechercher un événement</label>
        <input type="text" id="search" class="form-control w-50 mx-auto" placeholder="Rechercher un événement...">
    </div>

    <div class="row" id="hackathon-list">
        {% for h in hackathons %}
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm cardDraggable" id="{{ h.id }}">
                    <img src="{{ h.photo_url }}"
                         draggable="false"
                         class="card-img-top"
                         alt="{{ h.nom }}"
                         loading="lazy"
                         style="height: 200px; object-fit: cover; width: 100%;">

                    <div class="card-body">
                        <h5 class="card-title">{{ h.nom }}</h5>
                        <p class="card-text text-truncate">{{ h.description }}</p>
                        <p class="text-muted">📅 {{ h.date_event|date("d/m/Y") }}</p>
                        <p class="fw-bold">{{ h.prix > 0 ? h.prix ~ ' €' : 'Gratuit' }}</p>

                        <a href="/hackathon?id={{ h.id }}" class="btn btn-primary w-100">Voir détails</a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info">Aucun hackathon prévu pour le moment.</div>
            </div>
        {% endfor %}
    </div>

    <div id="compare-container" style="position: fixed; bottom: 30px; right: 30px; z-index: 1000; display: none;">
        <button id="btn-compare" class="btn btn-success btn-lg shadow-lg rounded-pill px-4">
            Comparer (<span id="compare-count">0</span>)
        </button>
    </div>
{% endblock %}