{% extends "layout.html.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <div class="row mt-4">
        <div class="col-md-8 mx-auto">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <a href="/" class="btn btn-outline-secondary">← Retour à la liste</a>
                <a href="/hackathon/pdf?id={{ hackathon.id }}" class="btn btn-danger shadow-sm">
                    Télécharger le récapitulatif (PDF)
                </a>
            </div>

            <div class="card shadow-sm">
                <img src="{{ hackathon.photo_url ?: 'https://via.placeholder.com/800x300' }}"
                     class="card-img-top"
                     alt="{{ hackathon.nom }}"
                     loading="lazy"
                     style="height: 350px; object-fit: cover; width: 100%;">

                <div class="card-body">
                    <h2 class="card-title">{{ hackathon.nom }}</h2>
                    <div class="d-flex justify-content-between text-muted mb-4">
                        <span>{{ hackathon.date_event|date("d/m/Y à H:i") }}</span>
                        <span>{{ hackathon.ville }}</span>
                        <span class="fw-bold text-dark">{{ hackathon.prix > 0 ? hackathon.prix ~ ' €' : 'Gratuit' }}</span>
                    </div>

                    <hr>

                    <h5>Description du projet</h5>
                    <p class="card-text">{{ hackathon.description|nl2br }}</p>

                    {% if hackathon.latitude and hackathon.longitude %}
                        <hr>
                        <h5>Localisation</h5>
                        <div id="map" style="height: 300px; border-radius: 8px; border: 1px solid #ccc; z-index: 1;"></div>
                    {% endif %}

                    <hr>

                    <div class="alert alert-info mt-4">
                        <strong>Contact Organisateur :</strong> <a href="mailto:{{ hackathon.email_organisateur }}">{{ hackathon.email_organisateur }}</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% if hackathon.latitude and hackathon.longitude %}
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var lat = {{ hackathon.latitude }};
                var lng = {{ hackathon.longitude }};

                var map = L.map('map').setView([lat, lng], 13);

                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© OpenStreetMap'
                }).addTo(map);

                L.marker([lat, lng]).addTo(map)
                    .bindPopup("<b>{{ hackathon.nom|escape('js') }}</b><br>{{ hackathon.ville|escape('js') }}");
            });
        </script>
    {% endif %}
{% endblock %}